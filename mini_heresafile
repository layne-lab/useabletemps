#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <fcntl.h>

void serve_file(int client, char *filename) {
    int fd = open(filename, O_RDONLY);
    if (fd < 0) {
        char *not_found = "HTTP/1.1 404 Not Found\r\n\r\nFile not found";
        send(client, not_found, strlen(not_found), 0);
        return;
    }

    char *header = "HTTP/1.1 200 OK\r\n\r\n";
    send(client, header, strlen(header), 0);

    char buffer[1024];
    int bytes;
    while ((bytes = read(fd, buffer, sizeof(buffer))) > 0) {
        send(client, buffer, bytes, 0);
    }

    close(fd);
}

int main() {
    int server_fd = socket(AF_INET, SOCK_STREAM, 0);

    struct sockaddr_in server;
    server.sin_family = AF_INET;
    server.sin_addr.s_addr = INADDR_ANY;
    server.sin_port = htons(8080);

    bind(server_fd, (struct sockaddr *)&server, sizeof(server));
    listen(server_fd, 5);

    printf("Web server running on port 8080\n");

    while (1) {
        int client = accept(server_fd, NULL, NULL);

        char buffer[2048];
        recv(client, buffer, sizeof(buffer), 0);

        printf("Request:\n%s\n", buffer);

        if (strncmp(buffer, "GET / ", 6) == 0) {
            serve_file(client, "index.html");
        } else {
            serve_file(client, "404.html");
        }

        close(client);
    }
}
